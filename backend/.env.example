# ─── Server ───────────────────────────────────────────────────────────
PORT=5000

# ─── Database ─────────────────────────────────────────────────────────
# Local dev — discrete fields:
DB_HOST=localhost
DB_PORT=5432
DB_NAME=credent
DB_USER=postgres
DB_PASSWORD=your_db_password_here
# Production (Neon / Supabase / Render) — single connection string. If set,
# this overrides the discrete fields above. Must include ?sslmode=require.
# Example: DATABASE_URL=postgresql://user:pass@host.neon.tech/credent?sslmode=require
# DATABASE_URL=

# ─── AI cost guard ────────────────────────────────────────────────────
# Max paid Claude calls per user per UTC day. Agents/admins are uncapped.
# Default 30 if not set.
AI_DAILY_CAP=30

# ─── Anthropic ────────────────────────────────────────────────────────
# Server-side key for Emrys. Keep secret.
ANTHROPIC_API_KEY=your_anthropic_key_here

# ─── Uploads ──────────────────────────────────────────────────────────
# Absolute path to the uploads directory. Leave blank for local dev
# (defaults to ./uploads in the backend folder). On Render with a paid
# disk: UPLOAD_DIR=/var/data/uploads
# UPLOAD_DIR=

# ─── JWT ──────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_secure_random_secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=replace_with_different_secure_random_secret
JWT_REFRESH_EXPIRES_IN=7d

# ─── App ──────────────────────────────────────────────────────────────
NODE_ENV=development

# ─── CORS ─────────────────────────────────────────────────────────────
# Comma-separated list of allowed web origins (production only)
# Mobile apps (Android/iOS) do not send Origin headers — they are always allowed
# Example: CLIENT_URL=https://app.credent.com,https://admin.credent.com
CLIENT_URL=

# ─── Email ────────────────────────────────────────────────────────────
SENDGRID_API_KEY=your_sendgrid_api_key_here
EMAIL_FROM=noreply@yourdomain.com
EMAIL_FROM_NAME=Credent Support

# ─── Push notifications (FCM — Android) ───────────────────────────────
# Firebase console → Project settings → Service accounts → Generate new private key.
# Keep the JSON OUTSIDE the repo. Leave blank to disable Android push.
FCM_SERVICE_ACCOUNT_PATH=/abs/path/to/firebase-service-account.json

# ─── Push notifications (APNs — iOS, optional) ────────────────────────
# See IOS_PUSH_SETUP.md in CredentSwiftUI for the .p8 key flow.
# APNS_KEY_PATH=/abs/path/to/AuthKey_XXXXXXXXXX.p8
# APNS_KEY_ID=XXXXXXXXXX
# APNS_TEAM_ID=YYYYYYYYYY
# APNS_BUNDLE_ID=com.credent.app
# APNS_PRODUCTION=false
